let teachers = [
    { id: 1, name: "Иван Иванов", subject: "Математика", rating: 5, comments: [] },
    { id: 2, name: "Анна Петрова", subject: "Физика", rating: 4, comments: [] }
];


function addComment(teacherId, text) {
    const teacher = teachers.find(t => t.id === teacherId);
    if (teacher) {
        teacher.comments.push(text);
        console.log(`Комментарий добавлен учителю ${teacher.name}`);
    }
}


function findTeacher(name) {
    return teachers.filter(t => t.name.toLowerCase().includes(name.toLowerCase()));
}


function rateTeacher(teacherId, points) {
    const teacher = teachers.find(t => t.id === teacherId);
    if (teacher) {
        teacher.rating += points;
        console.log(`Рейтинг ${teacher.name} теперь: ${teacher.rating}`);
    }
}


console.log("--- Список учителей ---");
console.log(teachers);

console.log("\n--- Поиск учителя ---");
console.log(findTeacher("Иван"));

console.log("\n--- Действия ---");
addComment(1, "Отличный преподаватель!");
rateTeacher(2, 1);

console.log("\n--- Итоговый список ---");
console.log(teachers);
